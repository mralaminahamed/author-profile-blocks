{
	"name": "author-profile-blocks",
	"version": "1.0.0",
	"description": "A collection of powerful Gutenberg blocks for showcasing author profiles and team members using WordPress users.",
	"author": "Al Amin Ahamed <mrabir.ahamed@gmail.com>",
	"license": "GPL-3.0-only",
	"homepage": "https://github.com/mralaminahamed/author-profile-blocks",
	"repository": {
		"type": "git",
		"url": "https://github.com/mralaminahamed/author-profile-blocks.git"
	},
	"bugs": {
		"url": "https://github.com/mralaminahamed/author-profile-blocks/issues"
	},
	"keywords": [
		"wordpress",
		"plugin",
		"gutenberg",
		"block",
		"author",
		"profile"
	],
	"main": "build/index.js",
	"engines": {
		"node": ">=16.0.0",
		"npm": ">=8.0.0"
	},
	"scripts": {
		"start": "wp-scripts start --webpack-copy-php",
		"build": "wp-scripts build --webpack-copy-php",
		"lint": "yarn lint:js && yarn lint:css && yarn lint:md:docs && yarn lint:pkg-json",
		"plugin-zip": "wp-scripts plugin-zip --root-folder=author-profile-blocks",
		"wp:make-pot": "wp i18n make-pot . languages/author-profile-blocks.pot",
		"bundle-analyze": "wp-scripts build --webpack-copy-php --webpack-bundle-analyzer"
	},
	"devDependencies": {
		"@babel/core": "^7.26.10",
		"@playwright/test": "^1.52.0",
		"@wordpress/api-fetch": "^7.22.0",
		"@wordpress/block-editor": "^14.17.0",
		"@wordpress/blocks": "^14.11.0",
		"@wordpress/components": "^29.8.0",
		"@wordpress/compose": "^7.22.0",
		"@wordpress/core-data": "^7.22.0",
		"@wordpress/data": "^10.22.0",
		"@wordpress/element": "^6.22.0",
		"@wordpress/eslint-plugin": "^22.8.0",
		"@wordpress/i18n": "^5.22.0",
		"@wordpress/icons": "^10.22.0",
		"@wordpress/scripts": "^30.15.0",
		"@wordpress/server-side-render": "^5.22.0",
		"@wordpress/stylelint-config": "^23.14.0",
		"classnames": "^2.5.1",
		"eslint": "^9.25.1",
		"eslint-plugin-react": "^7.37.5",
		"jquery": "^3.7.1",
		"prettier": "^3.5.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"slick-carousel": "^1.8.1",
		"stylelint": "^16.19.0",
		"stylelint-config-recess-order": "^6.0.0",
		"stylelint-scss": "^6.11.1",
		"typescript": "^5.8.3",
		"wp-readme-to-markdown": "^1.0.1"
	},
	"files": [
		"build",
		"includes",
		"languages",
		"vendor/composer",
		"vendor/autoload.php",
		"index.php",
		"author-profile-blocks.php",
		"readme.txt",
		"readme.md",
		"LICENSE"
	],
	"packageManager": "yarn@4.9.0"
}
