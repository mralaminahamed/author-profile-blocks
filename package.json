{
	"name": "author-profile-showcase",
	"version": "1.0.0",
	"description": "Showcase author profiles with a beautiful Gutenberg block that displays author information from a custom post type.",
	"author": "Al Amin Ahamed <mrabir.ahamed@gmail.com>",
	"license": "GPL-3.0-only",
	"homepage": "https://github.com/mralaminahamed/author-profile-showcase",
	"repository": {
		"type": "git",
		"url": "https://github.com/mralaminahamed/author-profile-showcase.git"
	},
	"bugs": {
		"url": "https://github.com/mralaminahamed/author-profile-showcase/issues"
	},
	"keywords": [
		"wordpress",
		"plugin",
		"gutenberg",
		"block",
		"author",
		"profile"
	],
	"main": "build/index.js",
	"engines": {
		"node": ">=16.0.0",
		"npm": ">=8.0.0"
	},
	"scripts": {
		"start": "wp-scripts start --webpack-copy-php",
		"build": "wp-scripts build --webpack-copy-php",
		"lint": "yarn lint:js && yarn lint:css && yarn lint:md:docs && yarn lint:pkg-json",
		"plugin-zip": "wp-scripts plugin-zip --root-folder=author-profile-showcase",
		"wp:make-pot": "wp i18n make-pot . languages/author-profile-showcase.pot",
		"bundle-analyze": "wp-scripts build --webpack-copy-php --webpack-bundle-analyzer"
	},
	"devDependencies": {
		"@babel/core": "^7.26.10",
		"@playwright/test": "^1.51.1",
		"@wordpress/api-fetch": "^7.21.0",
		"@wordpress/block-editor": "^14.16.0",
		"@wordpress/blocks": "^14.10.0",
		"@wordpress/components": "^29.7.0",
		"@wordpress/compose": "^7.21.0",
		"@wordpress/data": "^10.21.0",
		"@wordpress/element": "^6.21.0",
		"@wordpress/eslint-plugin": "^22.7.0",
		"@wordpress/i18n": "^5.21.0",
		"@wordpress/icons": "^10.22.0",
		"@wordpress/scripts": "^30.14.1",
		"@wordpress/server-side-render": "^5.21.0",
		"@wordpress/stylelint-config": "^23.13.0",
		"classnames": "^2.5.1",
		"eslint": "^9.24.0",
		"eslint-plugin-react": "^7.37.5",
		"prettier": "^3.5.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"stylelint": "^16.18.0",
		"typescript": "^5.8.3"
	},
	"files": [
		"build",
		"includes",
		"languages",
		"vendor/composer",
		"vendor/autoload.php",
		"index.php",
		"author-profile-showcase.php",
		"readme.txt",
		"readme.md",
		"LICENSE"
	],
	"packageManager": "yarn@4.9.0"
}
