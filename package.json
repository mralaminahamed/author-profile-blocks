		"@wordpress/stylelint-config": "^23.13.0",
		"classnames": "^2.5.1",
		"eslint": "^9.24.0",
		"eslint-plugin-react": "^7.37.5",
		"prettier": "^3.5.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"stylelint": "^16.18.0",
		"typescript": "^5.8.3"
	},
