{
	"name": "@mralaminahamed/wp-author-showcase",
	"version": "1.0.0",
	"description": "Showcase author profiles with a beautiful Gutenberg block that displays author information from a custom post type.",
	"author": "Al Amin Ahamed <mrabir.ahamed@gmail.com>",
	"license": "GPL-3.0-only",
	"homepage": "https://github.com/mralaminahamed/wp-author-showcase",
	"repository": {
		"type": "git",
		"url": "https://github.com/mralaminahamed/wp-author-showcase.git"
	},
	"bugs": {
		"url": "https://github.com/mralaminahamed/wp-author-showcase/issues"
	},
	"keywords": [
