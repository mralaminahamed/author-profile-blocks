{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-author-showcase/author-profile",
	"version": "1.0.0",
	"title": "Author Profile",
	"category": "widgets",
	"icon": "admin-users",
	"description": "Showcase author profiles with a beautiful Gutenberg block that displays author information from a custom post type.",
	"attributes": {
		"authorId": {
			"type": "number",
			"default": 0
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"showEmail": {
			"type": "boolean",
			"default": true
		},
		"showDescription": {
			"type": "boolean",
			"default": true
		},
		"showMore": {
			"type": "boolean",
			"default": false
		},
		"moreContent": {
			"type": "string",
			"default": ""
		},
		"backgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"textAlign": {
			"type": "string",
			"default": "left"
		},
		"padding": {
			"type": "number",
			"default": 20
		}
	},
	"example": {
		"attributes": {
      "textAlign": "left",
      "showImage": true,
      "showEmail": true,
      "showDescription": true,
      "showMore": true,
      "moreContent": "This is an example of the additional content section.",
			"backgroundColor": "#f8f9fa",
			"padding": 25
		},
		"viewportWidth": 800
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"textdomain": "wp-author-showcase",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
