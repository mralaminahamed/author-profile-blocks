{
  "name": "mralaminahamed/author-profile-blocks",
  "description": "A collection of powerful Gutenberg blocks for showcasing author profiles and team members using WordPress users.",
  "license": "GPL-2.0-or-later",
  "type": "wordpress-plugin",
  "version": "1.0.4",
  "authors": [
    {
      "name": "Al Amin Ahamed",
      "email": "mrabir.ahamed@gmail.com",
      "homepage": "https://github.com/mralaminahamed/"
    }
  ],
  "homepage": "https://github.com/mralaminahamed/author-profile-blocks",
  "support": {
    "issues": "https://github.com/mralaminahamed/author-profile-blocks/issues",
    "source": "https://github.com/mralaminahamed/author-profile-blocks"
  },
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "brain/monkey": "^2.6",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "ergebnis/composer-normalize": "^2.50",
    "php-stubs/wordpress-stubs": "^6.4",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.13",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.2",
    "wp-phpunit/wp-phpunit": "dev-master",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "AuthorProfileBlocks\\": "includes/"
    },
    "classmap": [
      "class-author-profile-blocks.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "AuthorProfileBlocks\\Test\\": "tests/php/src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "phpstan/extension-installer": true
    },
    "classmap-authoritative": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "7.4"
    }
  },
  "scripts": {
    "gen-assets": "php resources/banners-icons/generate.php",
    "gen-screenshots": "php resources/banners-icons/generate-screenshots.php",
    "gen-svg": "php resources/banners-icons/generate-svg.php",
    "makepot": "wp i18n make-pot . languages/author-profile-blocks.pot --exclude=node_modules,vendor,drafts,docs,build,release,tests",
    "phpcbf": "phpcbf --standard=phpcs.xml",
    "phpcbf:plugin-review": [
      "Composer\\Config::disableProcessTimeout",
      "phpcbf --standard=phpcs.plugin-review.xml"
    ],
    "phpcs": "phpcs --standard=phpcs.xml",
    "phpcs:plugin-review": [
      "Composer\\Config::disableProcessTimeout",
      "phpcs --standard=phpcs.plugin-review.xml"
    ],
    "phpstan": "phpstan analyse --memory-limit 2G",
    "release": [
      "@phpcs",
      "@phpstan",
      "rm -rf release vendor build/*",
      "yarn build",
      "@makepot",
      "mkdir -p release",
      "composer install --no-dev --optimize-autoloader",
      "rsync -av --exclude-from=.distignore . release/author-profile-blocks/",
      "cd release && zip -r author-profile-blocks.zip author-profile-blocks/",
      "composer install"
    ],
    "test": "phpunit",
    "test-f": "phpunit --filter",
    "test:coverage": "phpunit --coverage-html=tests/coverage/html"
  }
}
