{
  "name": "mralaminahamed/wp-author-showcase",
  "description": "Showcase author profiles with a beautiful Gutenberg block that displays author information from a custom post type.",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-only",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Al Amin Ahamed",
      "email": "mrabir.ahamed@gmail.com",
      "homepage": "https://github.com/mralaminahamed/"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "psr-4": {
      "WPAuthorShowcase\\": "includes/"
    }
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "php-stubs/wordpress-stubs": "^6.7"
  },
  "scripts": {
    "phpcs": "phpcs --standard=WordPress",
    "phpcbf": "phpcbf --standard=WordPress",
    "phpstan": "phpstan analyse",
    "wp:make-pot": "wp i18n make-pot ./ ./languages/wp-author-showcase.pot --domain=wp-author-showcase --package-name=\"WP Author Showcase\"",
    "wp:update-po": "wp i18n update-po ./languages/wp-author-showcase.pot",
    "wp:make-php": "wp i18n make-php ./languages/",
    "wp:make-json": "wp i18n make-json ./languages/"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "composer/installers": true,
      "phpstan/extension-installer": true
    }
  }
}
