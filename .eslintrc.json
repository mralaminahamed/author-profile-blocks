{
    "root": true,
    "env": {
        "browser": true,
        "es2021": true,
        "jquery": true,
        "node": true
    },
    "extends": [
        "plugin:@wordpress/eslint-plugin/recommended",
        "plugin:@wordpress/eslint-plugin/esnext",
        "plugin:@wordpress/eslint-plugin/i18n",
        "plugin:@wordpress/eslint-plugin/react",
        "plugin:import/errors",
        "plugin:import/warnings"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "rules": {
        "indent": ["error", "tab"],
        "linebreak-style": ["error", "unix"],
        "quotes": ["error", "single"],
        "semi": ["error", "always"],
        "no-console": "warn",

        "prettier/prettier": "off"
    },
    "settings": {
        "import/resolver": {
            "alias": {
                "map": [
                    ["@", "./src"]
                ],
                "extensions": [".js", ".jsx", ".ts", ".tsx"]
            }
        }
    },
    "globals": {
        "wp": "readonly",
        "wpApiSettings": "readonly"
    },
    "ignorePatterns": [
        "node_modules/",
        "build/",
        "vendor/"
    ]
}
