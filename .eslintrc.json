{
    "root": true,
    "env": {
        "browser": true,
        "es2021": true,
        "jquery": true,
        "node": true
    },
    "extends": [
        "plugin:@wordpress/eslint-plugin/recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "rules": {
        "indent": ["error", "tab"],
        "linebreak-style": ["error", "unix"],
        "quotes": ["error", "single"],
        "semi": ["error", "always"],
        "no-console": "warn"
    },
    "globals": {
        "wp": "readonly",
        "wpApiSettings": "readonly"
    },
    "ignorePatterns": [
        "node_modules/",
        "build/",
        "vendor/"
    ]
}
