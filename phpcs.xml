<?xml version="1.0"?>
<ruleset name="Author Profile Blocks Coding Standards">
    <description>WordPress Coding Standards for Author Profile Blocks plugin</description>

    <!-- Scan all files in plugin -->
    <file>.</file>

    <!-- Exclude patterns -->
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>
    <exclude-pattern>/build/*</exclude-pattern>
    <exclude-pattern>/docs/*</exclude-pattern>
    <exclude-pattern>/languages/*</exclude-pattern>
    <exclude-pattern>/src/*</exclude-pattern>
    <exclude-pattern>/tests/*</exclude-pattern>
    <exclude-pattern>*.asset.php</exclude-pattern>

    <!-- Only scan PHP files -->
    <arg name="extensions" value="php"/>

    <!-- Show progress and sniff codes -->
    <arg value="ps"/>
    <arg name="colors"/>

    <!-- WordPress standards -->
    <rule ref="WordPress">
        <exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_key"/>
        <exclude name="WordPress.DB.SlowDBQuery.slow_db_query_meta_value"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
    </rule>

    <!-- Security specific rules -->
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>
    <rule ref="WordPress.Security.NonceVerification"/>
    <rule ref="WordPress.Security.EscapeOutput"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="author-profile-blocks"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="author_profile_blocks"/>
                <element value="apbl"/>
                <element value="APBL"/>
                <element value="AuthorProfileBlocks"/>
            </property>
        </properties>
        <!-- Allow our namespace structure -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedNamespaceFound"/>
    </rule>

    <!-- PHP compatibility checks -->
    <rule ref="PHPCompatibility"/>
    <config name="testVersion" value="7.4-"/>

    <!-- WordPress VIP specific rules for better code quality -->
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>

    <!-- Performance and best practices -->
    <rule ref="WordPress.DB.SlowDBQuery"/>

    <!-- Additional security -->
    <rule ref="WordPress.Security.SafeRedirect"/>
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>

    <!-- File organization -->
    <rule ref="PSR2.Methods.MethodDeclaration"/>
    <rule ref="PSR2.Classes.ClassDeclaration"/>

    <!-- Exclude specific directories from certain rules -->
    <rule ref="WordPress.WP.AlternativeFunctions">
        <exclude-pattern>*/includes/Common/*</exclude-pattern>
    </rule>

    <rule ref="WordPress.PHP.DevelopmentFunctions">
        <exclude-pattern>*/includes/Common/*</exclude-pattern>
    </rule>

    <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter.FoundAfterLastUsed">
        <exclude-pattern>*/includes/Supports/*</exclude-pattern>
    </rule>
</ruleset>
