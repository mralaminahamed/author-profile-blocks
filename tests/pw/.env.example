# Environment variables for Author Profile Blocks Playwright E2E tests.
# Copy to .env and adjust the values for your local environment.

# WordPress site base URL (no trailing slash).
BASE_URL=https://wc-affiliate.test

# WordPress admin credentials used by auth.setup.ts on first run.
WP_ADMIN_USER=admin
WP_ADMIN_PASS=password

# Force re-authentication even when a cached storage state exists.
# Set to 1 to wipe the cached session and log in fresh.
FORCE_AUTH=0

# Run the browser in headless mode (1 / true) or with a visible window (0 / false).
HEADLESS=true

# Slow each action by N seconds — handy for debugging.
SLOWMO=0

# CI flag — toggles retries and stricter timeouts in playwright.config.ts.
CI=false
