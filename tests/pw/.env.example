# Environment variables for Playwright E2E tests
# Copy this file to .env and update the values

# Base URL for the WordPress site
BASE_URL=http://localhost:8888

# WordPress admin credentials
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password

# Test database settings (if using a separate test DB)
WP_DB_HOST=localhost
WP_DB_NAME=wordpress_test
WP_DB_USER=root
WP_DB_PASSWORD=

# Whether to run tests in headless mode
HEADLESS=true

# Slow down test execution for debugging (in milliseconds)
SLOWMO=0

# Whether to skip setup tests (useful for faster iteration)
NO_SETUP=false

# CI environment flag
CI=false