# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Author Profile Blocks
# ──────────────────────────────────────────────────────────────────────────────

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/

# ─── Cache ────────────────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.parcel-cache/
.cache/
*.result.cache

# ─── PHP / Composer ───────────────────────────────────────────────────────────
vendor/
/composer.lock

# ─── Build output ─────────────────────────────────────────────────────────────
/build/
*.zip
*.tgz
*.tar.gz

# ─── Source maps ──────────────────────────────────────────────────────────────
*.css.map
*.js.map

# ─── Translations (compiled) ──────────────────────────────────────────────────
languages/*.mo
languages/*.pot~
languages/*.po~
languages/*.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
.nyc_output/


# ─── Extra ─────────────────────────────────────────────────────────────────
docs/superpowers/
docs/_config_local.yml
.remember/
.tmp/
/.playwright-mcp
package-lock.json
